# API Keys
ANTHROPIC_API_KEY=sk-your-key-here

# Database (PostgreSQL or SQLite)
DATABASE_URL=postgresql://postgres:password@localhost:5432/autopipeline
# Para SQLite local: DATABASE_URL=sqlite:///./autopipeline.db

# Azure
AZURE_SUBSCRIPTION_ID=
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
SYNAPSE_SERVER=
SYNAPSE_DATABASE=analytics
STORAGE_ACCOUNT=
APPINSIGHTS_KEY=
KEY_VAULT_NAME=

# Agent Config
AGENT_TIME_BUDGET_SECONDS=600
AGENT_COST_LIMIT_USD=5.0

# Development
DEBUG=false
LOG_LEVEL=info
SQL_ECHO=false
